# ── CourseDrop Bot Environment Variables ──
# Copy to .env and fill in your values.
# NEVER commit this file to GitHub!

# REQUIRED: Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# REQUIRED: Telegram Channel ID (e.g. @CourseDrop)
CHANNEL_ID=@CourseDrop

# OPTIONAL: Port for health server (Render sets this automatically)
PORT=8080
